# 服务配置
APP_NAME=rag-platform
APP_ENV=local
APP_DEBUG=true

# MySQL 配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=rag_platform

# Milvus 配置
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_chunk_vector

# DeepSeek 配置
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# RAG 参数
RAG_TOP_K=20
RAG_RERANK_TOP_K=5
RAG_CONTEXT_MAX_TOKENS=6000

# 文件上传目录
UPLOAD_DIR=storage/uploads

# 阿里 DashScope Embedding 配置
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
EMBEDDING_OUTPUT_TYPE=dense
DASHSCOPE_EMBEDDING_ENDPOINT=/api/v1/services/embeddings/text-embedding/text-embedding
EMBEDDING_BATCH_SIZE=10
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=3

# Milvus 向量索引配置
MILVUS_VECTOR_FIELD=embedding
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200

# Elasticsearch 配置
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_VERIFY_CERTS=false

ES_CHUNK_INDEX=rag_chunk_bm25
ES_ANALYZER=ik_max_word
ES_SEARCH_ANALYZER=ik_smart
ES_BM25_TOP_K=20
ES_INDEX_BATCH_SIZE=100

# Hybrid Search 配置
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4
HYBRID_FINAL_TOP_K=20

# Query 理解配置
QUERY_ANALYSIS_USE_LLM=true
QUERY_ANALYSIS_LLM_TIMEOUT_SECONDS=30
QUERY_ANALYSIS_MIN_CONFIDENCE=0.6

# 默认检索路由
DEFAULT_RETRIEVAL_MODE=hybrid
DEFAULT_QUERY_TOP_K=10

# RRF 融合配置
HYBRID_FUSION_METHOD=rrf
RRF_RANK_CONSTANT=60
RRF_WINDOW_SIZE=50

# 百炼 qwen3-rerank 配置
RERANK_ENABLED=true
RERANK_PROVIDER=dashscope
RERANK_MODEL=qwen3-rerank
DASHSCOPE_RERANK_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_RERANK_ENDPOINT=/compatible-api/v1/reranks
RERANK_TOP_N=5
RERANK_CANDIDATE_LIMIT=50
RERANK_TIMEOUT_SECONDS=60
RERANK_MAX_RETRIES=2
RERANK_FAIL_OPEN=true
RERANK_MIN_SCORE=0.0
RERANK_INSTRUCT=Given a user question, retrieve relevant enterprise knowledge passages that directly answer the question.


# Context 构建配置
CONTEXT_MAX_TOKENS=6000
CONTEXT_MAX_CHUNKS=8
CONTEXT_EXPAND_PARENT=true
CONTEXT_EXPAND_PREVIOUS_NEXT=true
CONTEXT_EXPAND_SAME_SECTION=true
CONTEXT_MAX_EXPANDED_CHUNKS_PER_HIT=2
CONTEXT_INCLUDE_METADATA_HEADER=true
CONTEXT_CITATION_PREFIX=C